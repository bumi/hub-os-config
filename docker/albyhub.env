# Seeded sample Alby Hub .env for local testing. The Advanced section reads and
# rewrites only RELAY, LDK_ESPLORA_SERVER and LN_BACKEND_TYPE; the unrelated key
# below should survive a save untouched.
RELAY=wss://relay.getalby.com/v1
LDK_ESPLORA_SERVER=https://mempool.space/api
LN_BACKEND_TYPE=LDK
WORK_DIR=/opt/albyhub/data
